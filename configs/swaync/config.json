{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "right",
  "positionY": "top",
  "layer": "top",
  "cssPriority": "user",

  "control-center-width": 380,
  "control-center-height": 720,
  "notification-window-width": 380,

  "notification-icon-size": 48,
  "notification-body-image-height": 120,
  "notification-body-image-width": 220,

  "fit-to-screen": true,
  "relative-timestamps": true,
  "timeout": 6,
  "timeout-low": 3,
  "timeout-critical": 0,

  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": true,
  "hide-on-action": true,
  "script-fail-notify": true,

  "widgets": [
    "label",
    "buttons-grid",
    "volume",
    "backlight",
    "mpris",
    "title",
    "dnd",
    "notifications"
  ],

  "widget-config": {

    "title": {
      "text": "󰂚 Notifications",
      "clear-all-button": true,
      "button-text": "󰆴 Clear"
    },

    "dnd": {
      "text": "󰂛 Do Not Disturb"
    },

    "label": {
      "max-lines": 1,
      "text": "Welcome, User!"
    },

    "mpris": {
      "image-size": 96,
      "image-radius": 14
    },

    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },

    "backlight": {
      "label": "󰃠"
    },

    "buttons-grid": {
      "actions": [
        {
          "label": "󰖩",
          "command": "swaync-client -cp; rofi -show wifi"
        },
        {
          "label": "󰂯",
          "command": "swaync-client -cp; rofi-bluetooth"
        },
        {
          "label": "󰐥",
          "command": "swaync-client -cp; sh ~/.config/yamiyo/rofi/power.sh"
        },
        {
          "label": "󰸉",
          "command": "swaync-client -cp; ~/.config/yamiyo/rofi/wall.sh"
        }
      ]
    }
  }
}